{
    "name": "timesheet_details",
    "schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
            "client_order_number": {"type": ["string", "null"]},
            "service_ref_number": {"type": ["string", "null"]},
            "engineer_name": {"type": ["string", "null"]},
            "client": {"type": ["string", "null"]},
            "plant": {"type": ["string", "null"]},
            "records": {
                "type": "array",
                "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "date": {"type": ["string", "null"]},
                        "day_name": {
                            "type": ["string", "null"],
                            "enum": [
                                "Sunday",
                                "Monday",
                                "Tuesday",
                                "Wednesday",
                                "Thursday",
                                "Friday",
                                "Saturday",
                                null
                            ]
                        },
                        "time_range": {"type": ["string", "null"]},
                        "start_time": {"type": ["string", "null"]},
                        "end_time": {"type": ["string", "null"]},
                        "work_duration_hours": {"type": ["number", "null"]},
                        "travel_duration_hours": {"type": ["number", "null"]},
                        "location": {"type": ["string", "null"]},
                        "description": {"type": ["string", "null"]},
                        "raw_text": {"type": ["string", "null"]}
                    },
                    "required": [
                        "date",
                        "day_name",
                        "time_range",
                        "start_time",
                        "end_time",
                        "work_duration_hours",
                        "travel_duration_hours",
                        "location",
                        "description",
                        "raw_text"
                    ]
                }
            }
        },
        "required": [
            "client_order_number",
            "service_ref_number",
            "engineer_name",
            "client",
            "plant",
            "records"
        ]
    }}
